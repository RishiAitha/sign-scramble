<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net7.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>disable</ImplicitUsings>
  </PropertyGroup>
  <!-- Rely on SDK default implicit inclusion of .cs files in the project directory.
       Explicitly listing all .cs files causes duplicate Compile items. -->
</Project>
